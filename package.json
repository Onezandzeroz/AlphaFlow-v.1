  "name": "alphaai-accounting",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "bun scripts/dev-server.ts",
    "dev:direct": "bun x next dev -p 3000 --webpack",
    "build": "bun x next build",
    "start": "bun x next start -p 3000",
    "start:pm2": "pm2 start ecosystem.config.js",
    "lint": "eslint .",
    "postinstall": "bun x prisma generate",
    "db:push": "bun x prisma db push",
