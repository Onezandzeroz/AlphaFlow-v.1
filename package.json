    "db:reset": "bun x prisma migrate reset",
    "kill-port": "bun scripts/kill-port.ts",
    "ports": "bun -e \"import { scanPorts, printPortStatus } from './src/lib/port-utils'; scanPorts().then(printPortStatus);\""
